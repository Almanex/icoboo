<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="IconForge.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IconForge"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel VerticalAlignment="Center">
                <TextBlock 
                    x:Uid="AppTitle"
                    Text="IconForge" 
                    Style="{ThemeResource TitleTextBlockStyle}" 
                    FontWeight="SemiBold" />
                <TextBlock 
                    x:Uid="AppSubtitle"
                    Text="Пакетный генератор иконок для Windows и Android" 
                    Style="{ThemeResource BodyTextBlockStyle}" 
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                    Margin="0,4,0,0" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button x:Name="AboutButton" Click="AboutButton_Click" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE946;" FontSize="14" />
                        <TextBlock x:Uid="AboutBtnText" Text="О программе" />
                    </StackPanel>
                </Button>
                <Image x:Name="AppLogoImage" Height="40" Width="40" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Main Workspace -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Configuration -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" Padding="0,0,12,0">

                    <!-- 1. Source File Card -->
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        
                        <StackPanel Padding="16" Spacing="12">
                            <TextBlock x:Uid="SourceFileHeader" Text="Исходный файл" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                            
                            <!-- Drag and Drop Area -->
                            <Border 
                                x:Name="DropZone"
                                BorderThickness="2"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                CornerRadius="6"
                                Height="140"
                                AllowDrop="True"
                                DragOver="DropZone_DragOver"
                                DragLeave="DropZone_DragLeave"
                                Drop="DropZone_Drop"
                                PointerPressed="DropZone_PointerPressed">
                                
                                <Grid>
                                    <!-- Empty State -->
                                    <StackPanel 
                                        x:Name="DropZoneEmptyState"
                                        VerticalAlignment="Center" 
                                        HorizontalAlignment="Center" 
                                        Spacing="8">
                                        <FontIcon 
                                            Glyph="&#xE8E5;" 
                                            FontSize="32" 
                                            Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                        <TextBlock 
                                            x:Name="DropZoneTitle"
                                            x:Uid="DropZoneText"
                                            Text="Перетащите файл сюда" 
                                            HorizontalAlignment="Center" 
                                            FontWeight="SemiBold" />
                                        <TextBlock 
                                            x:Uid="DropZoneSubtext"
                                            Text="Поддерживаются файлы PNG и SVG" 
                                            Style="{ThemeResource CaptionTextBlockStyle}" 
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                            HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Loaded State -->
                                    <Grid 
                                        x:Name="DropZoneLoadedState" 
                                        Visibility="Collapsed" 
                                        Padding="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border 
                                            Grid.Column="0" 
                                            Width="64" 
                                            Height="64" 
                                            Background="{ThemeResource ControlAltFillColorTertiaryBrush}"
                                            CornerRadius="4" 
                                            Padding="4"
                                            VerticalAlignment="Center">
                                            <Image x:Name="PreviewImage" Stretch="Uniform" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock x:Name="FileNameTextBlock" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="FileSizeTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock x:Name="FileTypeTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" FontWeight="Medium" />
                                        </StackPanel>

                                        <Button 
                                            Grid.Column="2" 
                                            Content="&#xE711;" 
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}" 
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            Click="RemoveFileButton_Click" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Button 
                                x:Name="BrowseButton"
                                x:Uid="BrowseButton"
                                Content="Выбрать файл на диске..." 
                                HorizontalAlignment="Stretch"
                                Click="BrowseButton_Click" />
                        </StackPanel>
                    </Border>

                    <!-- 2. Export Destination Card -->
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        
                        <StackPanel Padding="16" Spacing="12">
                            <TextBlock x:Uid="OutputDirHeader" Text="Папка назначения" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                            
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox 
                                    x:Name="OutputDirTextBox" 
                                    x:Uid="OutputDirTextBox"
                                    PlaceholderText="Выберите папку для сохранения иконок" 
                                    IsReadOnly="False"
                                    VerticalAlignment="Center" />
                                
                                <Button 
                                    x:Name="BrowseFolderButton"
                                    x:Uid="BrowseFolderButton"
                                    Grid.Column="1" 
                                    Click="BrowseFolderButton_Click"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Выбрать папку">
                                    <FontIcon Glyph="&#xED25;" />
                                </Button>

                                <Button 
                                    x:Name="OpenFolderButton"
                                    x:Uid="OpenFolderButton"
                                    Grid.Column="2" 
                                    Click="OpenFolderButton_Click"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Открыть папку в Explorer">
                                    <FontIcon Glyph="&#xE8DA;" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 3. Image Filters & Styling Card -->
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        
                        <StackPanel Padding="16" Spacing="12">
                            <TextBlock x:Uid="FiltersHeader" Text="Фильтры и коррекция цвета" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                            
                            <!-- Brightness -->
                            <StackPanel Spacing="2">
                                <Grid>
                                    <TextBlock x:Uid="BrightnessLabel" Text="Яркость" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Name="BrightnessValueText" Text="0" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                                <Slider x:Name="BrightnessSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="FilterSlider_ValueChanged" />
                            </StackPanel>

                            <!-- Contrast -->
                            <StackPanel Spacing="2">
                                <Grid>
                                    <TextBlock x:Uid="ContrastLabel" Text="Контраст" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Name="ContrastValueText" Text="0" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                                <Slider x:Name="ContrastSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="FilterSlider_ValueChanged" />
                            </StackPanel>

                            <!-- Corner Radius & Padding -->
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock x:Uid="CornerRadiusLabel" Text="Скругление (%)" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <Slider x:Name="CornerRadiusSlider" Minimum="0" Maximum="50" Value="0" ValueChanged="FilterSlider_ValueChanged" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock x:Uid="PaddingLabel" Text="Отступ (%)" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <Slider x:Name="PaddingSlider" Minimum="0" Maximum="40" Value="0" ValueChanged="FilterSlider_ValueChanged" />
                                </StackPanel>
                            </Grid>

                            <!-- Toggles -->
                            <StackPanel Spacing="6">
                                <CheckBox x:Name="GrayscaleCheckBox" x:Uid="GrayscaleLabel" Content="Черно-белый режим" Click="FilterOption_Changed" />
                                <CheckBox x:Name="InvertCheckBox" x:Uid="InvertLabel" Content="Инверсия цветов" Click="FilterOption_Changed" />
                                <CheckBox x:Name="DropShadowCheckBox" x:Uid="DropShadowLabel" Content="Тень (Drop Shadow)" Click="FilterOption_Changed" />
                            </StackPanel>

                            <!-- Tint Color -->
                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="TintColorLabel" Text="Цветовой оттенок (SVG Tint)" Style="{ThemeResource CaptionTextBlockStyle}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="TintColorPreview" Width="28" Height="28" CornerRadius="14" Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />
                                    <TextBox Grid.Column="1" x:Name="TintColorTextBox" x:Uid="TintColorTextBox" Text="" PlaceholderText="Hex #RRGGBB (опционально)" TextChanged="TintColorTextBox_TextChanged" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 4. Android Customization Card -->
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        
                        <StackPanel Padding="16" Spacing="12">
                            <TextBlock x:Uid="AndroidSettingsHeader" Text="Настройки Android" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                            
                            <!-- Background color field -->
                            <StackPanel Spacing="6">
                                <TextBlock x:Uid="AndroidBgColorText" Text="Цвет заднего фона адаптивной иконки" Style="{ThemeResource BodyTextBlockStyle}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border 
                                        x:Name="BgColorPreview" 
                                        Width="32" 
                                        Height="32" 
                                        CornerRadius="16" 
                                        Background="White" 
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                        BorderThickness="1" />
                                    
                                    <TextBox 
                                        Grid.Column="1" 
                                        x:Name="BgColorTextBox" 
                                        Text="#FFFFFF" 
                                        MaxLength="9"
                                        PlaceholderText="#RRGGBB" 
                                        TextChanged="BgColorTextBox_TextChanged" />
                                </Grid>
                            </StackPanel>

                            <!-- Color Swatches -->
                            <StackPanel Spacing="6">
                                <TextBlock x:Uid="QuickColorsText" Text="Быстрые цвета:" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="44" ItemHeight="36" MaximumRowsOrColumns="6">
                                    <Button Width="32" Height="32" CornerRadius="16" Background="White" BorderThickness="1" Click="Swatch_Click" Tag="#FFFFFF" ToolTipService.ToolTip="Белый (#FFFFFF)" />
                                    <Button Width="32" Height="32" CornerRadius="16" Background="Black" BorderThickness="1" Click="Swatch_Click" Tag="#000000" ToolTipService.ToolTip="Черный (#000000)" />
                                    <Button Width="32" Height="32" CornerRadius="16" Background="#A4C2F4" BorderThickness="1" Click="Swatch_Click" Tag="#A4C2F4" ToolTipService.ToolTip="Пастельный синий (#A4C2F4)" />
                                    <Button Width="32" Height="32" CornerRadius="16" Background="#3DDC84" BorderThickness="1" Click="Swatch_Click" Tag="#3DDC84" ToolTipService.ToolTip="Android Green (#3DDC84)" />
                                    <Button Width="32" Height="32" CornerRadius="16" Background="#0078D4" BorderThickness="1" Click="Swatch_Click" Tag="#0078D4" ToolTipService.ToolTip="Windows Accent (#0078D4)" />
                                    <Button Width="32" Height="32" CornerRadius="16" Background="#212121" BorderThickness="1" Click="Swatch_Click" Tag="#212121" ToolTipService.ToolTip="Темный серый (#212121)" />
                                </VariableSizedWrapGrid>
                            </StackPanel>

                            <!-- Custom Background Image -->
                            <StackPanel Spacing="6" Margin="0,4,0,0">
                                <CheckBox x:Name="UseBgImageCheckBox" x:Uid="UseBgImageCheckBox" Content="Использовать фоновое изображение" Checked="UseBgImage_Changed" Unchecked="UseBgImage_Changed" />
                                <Grid ColumnSpacing="8" x:Name="BgImagePickerGrid" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="BgImagePathTextBox" x:Uid="BgImagePathTextBox" PlaceholderText="Файл изображения для фона" IsReadOnly="True" />
                                    <Button x:Name="BrowseBgImageButton" Grid.Column="1" Click="BrowseBgImageButton_Click">
                                        <FontIcon Glyph="&#xE8E5;" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel: Operations & Progress -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
                    <StackPanel Spacing="16">
                        
                        <!-- 4. Export Formats Card -->
                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            
                            <StackPanel Padding="16" Spacing="12">
                                <TextBlock x:Uid="ExportParamsHeader" Text="Параметры экспорта" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                                
                                <CheckBox x:Name="WindowsIcoCheckBox" x:Uid="WindowsIcoCheckBox" IsChecked="True" Content="Windows (Классический .ico)" />
                                <TextBlock 
                                    x:Uid="WindowsIcoSubtext"
                                    Text="Мультиформатный контейнер (16-256px) с микро-шарпингом для мелких размеров." 
                                    Style="{ThemeResource CaptionTextBlockStyle}" 
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                    Margin="28,-8,0,4" 
                                    TextWrapping="Wrap" />

                                <CheckBox x:Name="WindowsAssetsCheckBox" x:Uid="WindowsAssetsCheckBox" IsChecked="True" Content="Windows Assets (Square PNGs)" />
                                <TextBlock 
                                    x:Uid="WindowsAssetsSubtext"
                                    Text="Раздельные PNG логотипы в масштабах от 100% до 400% для UWP/WinUI манифестов." 
                                    Style="{ThemeResource CaptionTextBlockStyle}" 
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                    Margin="28,-8,0,4" 
                                    TextWrapping="Wrap" />

                                <CheckBox x:Name="AndroidAdaptiveCheckBox" x:Uid="AndroidAdaptiveCheckBox" IsChecked="True" Content="Android Adaptive &amp; Legacy" />
                                <TextBlock 
                                    x:Uid="AndroidAdaptiveSubtext"
                                    Text="Нарезка слоев Foreground, Background по MIPMAP плотностям, legacy-круг и Google Play 512x512." 
                                    Style="{ThemeResource CaptionTextBlockStyle}" 
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                    Margin="28,-8,0,4" 
                                    TextWrapping="Wrap" />

                                <CheckBox x:Name="FaviconPackageCheckBox" x:Uid="ExportWebFaviconLabel" IsChecked="False" Content="Web &amp; Favicon Pack (ico, png, manifest)" />
                                <CheckBox x:Name="MacIcnsCheckBox" x:Uid="ExportMacIcnsLabel" IsChecked="False" Content="macOS App Icon (.icns)" />
                            </StackPanel>
                        </Border>

                        <!-- Live Pixel Preview Grid Card -->
                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            
                            <StackPanel Padding="16" Spacing="12">
                                <Grid>
                                    <TextBlock x:Uid="PreviewGridHeader" Text="Предпросмотр по размерам" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                                    
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                        <Button x:Name="PreviewBgTransparentBtn" Width="28" Height="28" Padding="0" Click="PreviewBg_Click" Tag="Transparent" ToolTipService.ToolTip="Прозрачный">
                                            <FontIcon Glyph="&#xE790;" FontSize="12" />
                                        </Button>
                                        <Button x:Name="PreviewBgDarkBtn" Width="28" Height="28" Padding="0" Click="PreviewBg_Click" Tag="Dark" ToolTipService.ToolTip="Темный фон">
                                            <Border Width="12" Height="12" Background="#1F1F1F" CornerRadius="2" />
                                        </Button>
                                        <Button x:Name="PreviewBgLightBtn" Width="28" Height="28" Padding="0" Click="PreviewBg_Click" Tag="Light" ToolTipService.ToolTip="Светлый фон">
                                            <Border Width="12" Height="12" Background="#F3F3F3" CornerRadius="2" BorderBrush="#CCC" BorderThickness="1" />
                                        </Button>
                                        <Button x:Name="PreviewBgCustomBtn" Width="28" Height="28" Padding="0" Click="PreviewBg_Click" Tag="CustomBg" ToolTipService.ToolTip="Цвет из настроек Android">
                                            <Border x:Name="PreviewBgCustomIndicator" Width="12" Height="12" Background="White" CornerRadius="6" BorderBrush="#888" BorderThickness="1" />
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <Border x:Name="PreviewGridContainer" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="6" Padding="12" MinHeight="140">
                                    <Grid ColumnSpacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 256x256 preview -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                            <Border Width="64" Height="64" CornerRadius="4">
                                                <Image x:Name="Preview256" Stretch="Uniform" />
                                            </Border>
                                            <TextBlock Text="256x256" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                        </StackPanel>

                                        <!-- 48x48 preview -->
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                            <Border Width="48" Height="48" CornerRadius="4">
                                                <Image x:Name="Preview48" Stretch="Uniform" />
                                            </Border>
                                            <TextBlock Text="48x48" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                        </StackPanel>

                                        <!-- 32x32 preview -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                            <Border Width="32" Height="32" CornerRadius="4">
                                                <Image x:Name="Preview32" Stretch="Uniform" />
                                            </Border>
                                            <TextBlock Text="32x32" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                        </StackPanel>

                                        <!-- 16x16 preview -->
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                            <Border Width="16" Height="16" CornerRadius="2">
                                                <Image x:Name="Preview16" Stretch="Uniform" Width="16" Height="16" />
                                            </Border>
                                            <TextBlock Text="16x16" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 5. System Integration Card -->
                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            
                            <StackPanel Padding="16" Spacing="8">
                                <TextBlock x:Uid="SysIntegrationHeader" Text="Системная интеграция" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                                
                                <ToggleSwitch 
                                    x:Name="ContextMenuToggle" 
                                    x:Uid="ContextMenuToggle"
                                    Header="Контекстное меню Windows" 
                                    Toggled="ContextMenuToggle_Toggled" />
                                <TextBlock 
                                    x:Uid="ContextMenuSubtext"
                                    Text="Добавить в контекстное меню Explorer пункт 'Сгенерировать иконки в IconForge'" 
                                    Style="{ThemeResource CaptionTextBlockStyle}" 
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                    Margin="0,-4,0,0" 
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Progress Section -->
                        <Border 
                            x:Name="ProgressCard"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                            
                            <StackPanel Padding="16" Spacing="10">
                                <TextBlock x:Name="ProgressStatusTextBlock" x:Uid="ProgressIdleText" Text="Ожидание..." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="Medium" />
                                <ProgressBar x:Name="GenerationProgressBar" Minimum="0" Maximum="100" Value="0" IsIndeterminate="False" Height="4" />
                                
                                <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="4" Padding="8">
                                    <TextBlock x:Name="LogTextBlock" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- 6. Generate Action Panel -->
                <StackPanel Grid.Row="1" Spacing="12" Margin="0,16,0,0">
                    <!-- ICO Frame Extraction Panel -->
                    <Border 
                        x:Name="IcoExtractCard" 
                        Visibility="Collapsed" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource SystemControlHighlightAccentBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8">
                        <StackPanel Padding="16" Spacing="10">
                            <TextBlock x:Uid="IcoExtractHeader" Text="Извлечение кадров из ICO" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Medium" />
                            <TextBlock x:Name="IcoExtractInfoText" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button 
                                x:Name="ExtractButton" 
                                x:Uid="ExtractBtn" 
                                Content="Извлечь все кадры в PNG" 
                                Style="{StaticResource AccentButtonStyle}" 
                                HorizontalAlignment="Stretch" 
                                Click="ExtractButton_Click" />
                        </StackPanel>
                    </Border>

                    <Button 
                        x:Name="GenerateButton" 
                        x:Uid="GenerateButton"
                        Content="Сгенерировать иконки" 
                        Style="{StaticResource AccentButtonStyle}" 
                        HorizontalAlignment="Stretch" 
                        Height="42" 
                        FontWeight="SemiBold"
                        Click="GenerateButton_Click" />
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Page>
